# Prisma (SQLite for dev, PostgreSQL for production)
DATABASE_URL="file:./dev.db"

# NextAuth / Auth.js
AUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars-long"
AUTH_URL="http://localhost:3000"

# Cloudinary — get these from https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Public site URL — used for SEO metadata and canonical links
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin authentication — the email used to sign in at /admin/login
ADMIN_EMAIL=admin@luxehairstudio.com

# Resend (transactional email) — get your API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxx

# Email sender address — must be a verified domain in Resend
EMAIL_FROM=hello@luxehairstudio.com
